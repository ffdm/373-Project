/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_TIM2_Init();
  MX_TIM3_Init();
  MX_USART2_UART_Init();
  MX_LPUART1_UART_Init();
  /* USER CODE BEGIN 2 */

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */

  // 1A = PA3
  // 2A = PC0
  // 3A = PC3
  // 4A = PC1

  // Turning right wheels forwards =
  	  // 1A to VCC, 2A to ground
  // Turning right wheels backwards =
  	  // 1A to ground, 2A to VCC
  // Turning left wheels forwards =
  	  // 3A to VCC, 4A to ground
  // Turning left wheels backwards =
  	  // 3A to ground, 4A to VCC

  // ENA = Timer 2 Channel 1 (PA5)
  // ENB = Timer 3 Channel 2 (PA7)

  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);
  HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_2);

  #define CCR1_offset 0x34
  #define CCR2_offset 0x38
  #define TIM2_ADDR 0x40000000
  #define TIM3_ADDR 0x40000400

  volatile uint32_t* TIM2CCR1 = (volatile uint32_t*) (TIM2_ADDR + CCR1_offset);
  volatile uint32_t* TIM3CCR2 = (volatile uint32_t*) (TIM3_ADDR + CCR2_offset);

  *TIM2CCR1 = 99;
  *TIM3CCR2 = 99;

  uint8_t rx_data[6];
  while (1)
  {
	  HAL_UART_Receive(&huart2, rx_data, 6, 10);

	  uint8_t buttons1 = rx_data[0];
	  uint8_t buttons2 = rx_data[1];
	  uint8_t Rx = rx_data[2];
	  uint8_t Ry = rx_data[3];
	  uint8_t Lx = rx_data[4];
	  uint8_t Ly = rx_data[5];

	  uint8_t buttons_array[16];
	  for(int i = 15; i >= 7; --i) {
		  buttons_array[i] = buttons1 & (1 << i) >> i;
	  }
	  for(int i = 7; i >= 0; --i) {
		  buttons_array[i] = buttons2 & (1 << i) >> i;
	  }

	  for(int i = 0; i < 15; i++) {
		  printf("%d", buttons_array[i]);
	  }
	  printf("\n");

	  // Digital Buttons from Controller
	  uint8_t L1, L2, R1, R2, Left, Up, Right, Down, Triangle, Circle, X, Square, Start, Select, RightPress, LeftPress;

	  Left = buttons1 & (1 << 7) >> 7;
	  Down = buttons1 & (1 << 6) >> 6;
	  Right = buttons1 & (1 << 5) >> 5;
	  Up = buttons1 & (1 << 4) >> 4;
	  Start = buttons1 & (1 << 3) >> 3;
	  RightPress = buttons1 & (1 << 2) >> 2;
	  LeftPress = buttons1 & (1 << 1) >> 1;
	  Select = buttons1 & (1 << 0) >> 0;

	  Square = buttons2 & (1 << 7) >> 7;
	  X = buttons2 & (1 << 6) >> 6;
	  Circle = buttons2 & (1 << 5) >> 5;
	  Triangle = buttons2 & (1 << 4) >> 4;
	  R1 = buttons2 & (1 << 3) >> 3;
	  L1 = buttons2 & (1 << 2) >> 2;
	  R2 = buttons2 & (1 << 1) >> 1;
	  L2 = buttons2 & (1 << 0) >> 0;


	  // inside buttons1:
	  // Left, Down, Right, Up, start, right joystick click, left joystick click, select
	  // inside buttons2:
	  // square, x, circle, triangle, R1, L1, R2, L2
	  printf("buttons2: ");

	  void print_int(uint8_t x) {
		  for(int i = 7; i >= 0; i--) {
			  int val = (x & (1 << i)) >> i;
			  printf("%d ", val);
		  }
	  }
	  print_int(buttons2);

	  printf("\n");

	  if(Rx > 128) {
		  setRightWheel(FORWARD);
		  setLeftWheel(FORWARD);
	  }
	  else if(Rx < 128) {
		  setRightWheel(REVERSE);
		  setLeftWheel(REVERSE);
	  }
	  else {
		  setRightWheel(OFF);
		  setLeftWheel(OFF);
	  }

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

